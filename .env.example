OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high

DEEPGRAM_API_KEY=your-deepgram-key

# Google Identity Services web client ID. This is public by design.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Hosted waitlist records are forwarded to this durable HTTPS endpoint.
# Local development stores signups in the ignored data/waitlist.jsonl file.
WAITLIST_WEBHOOK_URL=https://your-waitlist-endpoint.example.com
WAITLIST_WEBHOOK_SECRET=replace-with-a-webhook-bearer-secret

GITHUB_TOKEN=github_pat_or_classic_token
GITHUB_OWNER=your-github-username

ARDUINO_CLI_PATH=/Applications/Arduino IDE.app/Contents/Resources/app/lib/backend/resources/arduino-cli
ARDUINO_FQBN=esp32:esp32:esp32

PORT=8787
