OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high

DEEPGRAM_API_KEY=your-deepgram-key

GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
WAITLIST_WEBHOOK_URL=https://your-waitlist-backend.example.com/intake
WAITLIST_WEBHOOK_SECRET=your-waitlist-webhook-secret

GITHUB_TOKEN=github_pat_or_classic_token
GITHUB_OWNER=your-github-username

ARDUINO_CLI_PATH=/Applications/Arduino IDE.app/Contents/Resources/app/lib/backend/resources/arduino-cli
ARDUINO_FQBN=esp32:esp32:esp32

PORT=8787
