{
  "name": "makeable-hardware-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "build": "node --check app.js && node --check server.mjs && node --check netlify/functions/api.mjs && node --test tests/board-profiles.test.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:compiler": "MAKEABLE_TEST_ARDUINO_CLI=$PWD/.makeable/toolchain/bin/arduino-cli node --test tests/compiler.integration.test.mjs",
    "toolchain:install": "bash scripts/install-arduino-toolchain.sh"
  }
}
