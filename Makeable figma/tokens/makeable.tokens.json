    "paper": { "$type": "color", "$value": "#FFFDF8" },
    "ink": { "$type": "color", "$value": "#111111" },
    "coral": { "$type": "color", "$value": "#F15A44" },
    "hotPink": { "$type": "color", "$value": "#F43B88" },
    "periwinkle": { "$type": "color", "$value": "#8C8CF4" },
    "mint": { "$type": "color", "$value": "#9FDCC9" },
    "lemon": { "$type": "color", "$value": "#FFD43B" },
